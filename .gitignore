cat > .gitignore << 'EOF'
# Environment
.env
*.env

# Python
venv/
venv_backup/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/

# Data & Cache
data/fastf1_cache/
data/spark_checkpoints/
data/spark_output/lap_features/
*.csv
notebooks/.ipynb_checkpoints/

# Cloud Credentials
*.json
!package.json
!package-lock.json

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
EOF